            "url": {"raw": "{{base_url}}/v1/api-keys", "host": ["{{base_url}}"], "path": ["v1","api-keys"]}}},
        {"name": "Revoke",
          "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {"raw": "{{base_url}}/v1/api-keys/:key_id", "host": ["{{base_url}}"], "path": ["v1","api-keys",":key_id"]}}}
      ]
    },
